<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Pin the API host to the ISRG (Let's Encrypt) roots that sign the
         Railway certificate. Pinning the root SPKIs (not the leaf) survives
         routine certificate renewals; the expiration date makes the pins
         fail open instead of bricking the app if the CA ever changes. -->
    <domain-config>
        <domain includeSubdomains="false">api-garapan.up.railway.app</domain>
        <pin-set expiration="2027-07-04">
            <!-- ISRG Root X1 -->
            <pin digest="SHA-256">C5+lpZ7tcVwmwQIMcRtPbsQtWLABXhQzejna0wHFr8M=</pin>
            <!-- ISRG Root X2 -->
            <pin digest="SHA-256">diGVwiVYbubAI3RW4hB9xU8e/CH2GnkuvVFZE8zmgzI=</pin>
        </pin-set>
    </domain-config>

    <!-- The documented emulator fallback (http://10.0.2.2:3000) needs an
         explicit cleartext exception since targetSdk 28+ blocks cleartext. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
