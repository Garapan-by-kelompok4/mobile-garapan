<?xml version="1.0" encoding="utf-8"?><!--
   Auto Backup rules for devices older than API 31.
   See https://developer.android.com/guide/topics/data/autobackup
-->
<full-backup-content>
    <!-- DataStore holds auth tokens and the cached user snapshot; neither is
         portable across devices (Keystore-bound) nor safe to ship to cloud backup. -->
    <exclude domain="file" path="datastore" />
</full-backup-content>
